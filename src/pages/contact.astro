---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import ContactForm from "../components/widgets/ContactForm.astro";
import LocationMap from "../components/widgets/LocationMap.astro";
import GsapReveal from "../components/widgets/GsapReveal.astro";

const metadata = {
    title: "Contact & Devis — Bis Repetita | Studio de Boxe Genève",
    description:
        "Contactez Bis Repetita pour réserver votre séance de boxe à Genève. Coaching privé, duo, trio ou programme corporate — demandez votre devis personnalisé.",
};
---

<BaseLayout {metadata}>
    <div class="theme-light">
        <!-- Split: contenu + formulaire -->
        <ContactForm />

        <!-- Map heading -->
        <section class="pt-8 pb-4 md:pt-16 md:pb-6">
            <Container>
                <GsapReveal animation="fadeUp">
                    <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold font-display tracking-tight text-center">
                        Où trouver le studio <span class="text-primary">Bis Repetita</span> ?
                    </h2>
                </GsapReveal>
            </Container>
        </section>

        <!-- Map -->
        <GsapReveal animation="fadeUp">
            <LocationMap />
        </GsapReveal>
    </div>
</BaseLayout>
