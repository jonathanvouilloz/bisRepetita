---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import PostItem from "../../../components/blog/PostItem.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  const posts = allPosts.filter((post) => post.data && post.data.pubDate);

  const tags = new Set<string>();
  posts.forEach((post) => {
    post.data.tags?.forEach((tag) => tags.add(tag));
  });

  return Array.from(tags).map((tag) => {
    return {
      params: { tag },
      props: {
        tag,
        posts: posts
          .filter((post) => post.data.tags?.includes(tag))
          .sort(
            (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
          ),
      },
    };
  });
}

const { tag, posts } = Astro.props;

const metadata = {
  title: `#${tag} — Blog Bis Repetita`,
  description: `Articles tagges "${tag}". Conseils et actualites par Bis Repetita Geneve.`,
};
---

<BaseLayout metadata={metadata}>
  <div class="theme-light">
    <div class="min-h-screen bg-background">
      <section class="pt-32 pb-12 md:pt-40 md:pb-16">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="mx-auto max-w-3xl text-center">
            <span
              class="section-label inline-block mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-primary"
            >
              Tag
            </span>
            <h1
              class="font-heading text-4xl font-medium tracking-tight text-foreground md:text-6xl"
            >
              #{tag}
            </h1>
            <p class="mt-4 text-lg text-muted-foreground">
              {posts.length} article{posts.length === 1 ? "" : "s"} avec ce tag.
            </p>
          </div>

          <div class="mx-auto mt-8 max-w-3xl">
            <div class="h-px w-full bg-border"></div>
          </div>
        </div>
      </section>

      <div class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
        <div class="mb-8">
          <a
            href="/blog"
            class="inline-flex items-center text-sm font-medium text-primary transition-colors hover:text-primary/80"
          >
            <svg
              class="mr-1 h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M7 16l-4-4m0 0l4-4m-4 4h18"></path>
            </svg>
            Tous les articles
          </a>
        </div>

        {
          posts.length === 0 ? (
            <div class="py-20 text-center">
              <p class="text-lg text-muted-foreground">
                Aucun article avec ce tag.
              </p>
            </div>
          ) : (
            <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
              {posts.map((post) => (
                <PostItem post={post} />
              ))}
            </div>
          )
        }
      </div>
    </div>
  </div>
</BaseLayout>
