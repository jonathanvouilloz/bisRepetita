---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import BlogHero from "../../../components/blog/BlogHero.astro";
import PostItem from "../../../components/blog/PostItem.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  const posts = allPosts.filter((post) => post.data && post.data.pubDate);

  const categories = new Set<string>();
  posts.forEach((post) => {
    if (post.data.category) {
      categories.add(post.data.category);
    }
  });

  const allCategories = posts
    .map((p) => p.data.category)
    .filter((c): c is string => !!c);

  return Array.from(categories).map((category) => {
    return {
      params: { category },
      props: {
        category,
        allCategories,
        posts: posts
          .filter((post) => post.data.category === category)
          .sort(
            (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
          ),
      },
    };
  });
}

const { category, allCategories, posts } = Astro.props;
const categoryLabel = category.charAt(0).toUpperCase() + category.slice(1);

const metadata = {
  title: `${categoryLabel} — Blog Bis Repetita`,
  description: `Articles dans la categorie ${categoryLabel}. Conseils et actualites par Bis Repetita Geneve.`,
};
---

<BaseLayout metadata={metadata}>
  <div class="theme-light">
    <div class="min-h-screen bg-background">
      <BlogHero
        title={categoryLabel}
        subtitle={`${posts.length} article${posts.length === 1 ? "" : "s"} dans cette categorie.`}
        categories={allCategories}
        activeCategory={category}
      />

      <div class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
        <div class="mb-8">
          <a
            href="/blog"
            class="inline-flex items-center text-sm font-medium text-primary transition-colors hover:text-primary/80"
          >
            <svg
              class="mr-1 h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M7 16l-4-4m0 0l4-4m-4 4h18"></path>
            </svg>
            Tous les articles
          </a>
        </div>

        {
          posts.length === 0 ? (
            <div class="py-20 text-center">
              <p class="text-lg text-muted-foreground">
                Aucun article dans cette categorie.
              </p>
            </div>
          ) : (
            <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
              {posts.map((post) => (
                <PostItem post={post} />
              ))}
            </div>
          )
        }
      </div>
    </div>
  </div>
</BaseLayout>
