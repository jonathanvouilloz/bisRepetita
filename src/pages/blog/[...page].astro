---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import BlogHero from "../../components/blog/BlogHero.astro";
import PostFeatured from "../../components/blog/PostFeatured.astro";
import PostItem from "../../components/blog/PostItem.astro";
import Pagination from "../../components/ui/Pagination.astro";
import type { GetStaticPathsOptions } from "astro";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const blogEntries = await getCollection("blog");
  const sortedPosts = blogEntries
    .filter((post) => post.data && post.data.pubDate)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return paginate(sortedPosts, { pageSize: 7 });
}

const { page } = Astro.props;
const allPosts = page.data;
const isFirstPage = page.currentPage === 1;

const featuredPost = isFirstPage && allPosts.length > 0 ? allPosts[0] : null;
const gridPosts = isFirstPage ? allPosts.slice(1) : allPosts;

const allBlogEntries = await getCollection("blog");
const allCategories = allBlogEntries
  .map((p) => p.data.category)
  .filter((c): c is string => !!c);

const metadata = {
  title: "Blog — Conseils boxe, entrainement et bien-etre",
  description:
    "Actualites, conseils et articles sur la boxe, l'entrainement et le bien-etre par le studio Bis Repetita a Geneve. Techniques, nutrition et mental.",
};
---

<BaseLayout metadata={metadata}>
  <div class="theme-light">
    <div class="min-h-screen bg-background">
      <BlogHero categories={allCategories} />

      <div class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
        {
          allPosts.length === 0 ? (
            <div class="py-20 text-center">
              <p class="text-lg text-muted-foreground">
                Aucun article pour le moment.
              </p>
              <p class="mt-2 text-sm text-muted-foreground">
                Revenez bientot pour decouvrir nos premiers articles.
              </p>
            </div>
          ) : (
            <>
              {featuredPost && (
                <div class="mb-12">
                  <PostFeatured post={featuredPost} />
                </div>
              )}

              {gridPosts.length > 0 && (
                <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
                  {gridPosts.map((post) => (
                    <PostItem post={post} />
                  ))}
                </div>
              )}

              <Pagination page={page} />
            </>
          )
        }
      </div>
    </div>
  </div>
</BaseLayout>
