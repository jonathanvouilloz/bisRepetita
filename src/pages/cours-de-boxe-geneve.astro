---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/widgets/Hero.astro";
import Stats from "../components/widgets/Stats.astro";
import Features from "../components/widgets/Features.astro";
import EquipmentPanels from "../components/widgets/EquipmentPanels.astro";
import FAQ from "../components/widgets/FAQ.astro";
import CTABanner from "../components/widgets/CTABanner.astro";
import RelatedArticles from "../components/widgets/RelatedArticles.astro";
import GsapReveal from "../components/widgets/GsapReveal.astro";
import Container from "../components/ui/Container.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import Schema from "../components/seo/Schema.astro";
import coursPortrait from "../assets/cours-portrait.webp";
import nicolasPortrait from "../assets/nicolas-portrait.webp";
import studioAtmosphere from "../assets/studio-atmosphere.webp";
import cours2Landscape from "../assets/cours-2-landscape.webp";

const metadata = {
    title: "Cours de Boxe à Genève | Guide Complet 2026",
    description: "Tout savoir sur les cours de boxe à Genève : formats, tarifs, profils, premiers pas. Guide complet par Bis Repetita, studio de boxe premium.",
};

const stats = [
    { value: "15+", label: "Clubs à Genève", description: "Des clubs associatifs historiques aux studios privés — mais peu offrent un coaching véritablement personnalisé." },
    { value: "4", label: "Formats de pratique", description: "Solo, duo, petit groupe, collectif : trouvez celui qui correspond à vos objectifs et votre budget." },
    { value: "25-65", label: "Ans — tous les âges", description: "La boxe se pratique à tout âge. L'important, c'est l'encadrement et la progressivité." },
];

const profilPanels = [
    {
        title: "Le débutant curieux",
        description: "Vous n'avez jamais mis les gants ? C'est le profil le plus fréquent chez nous. On part de zéro, sans jugement, avec un programme adapté.",
        image: coursPortrait,
        alt: "Débutant en cours de boxe à Genève",
        ctaText: "Voir une première séance",
        ctaHref: "#premiere-seance",
    },
    {
        title: "La femme qui ose",
        description: "Cadre privé, sans contact, coaching bienveillant. La boxe au féminin chez Bis Repetita, c'est un espace pensé pour vous.",
        image: studioAtmosphere,
        alt: "Cours de boxe pour femme à Genève",
        ctaText: "Lire le guide boxe femme",
        ctaHref: "/blog/boxe-femme-geneve-guide-complet",
    },
    {
        title: "Le sportif en reconversion",
        description: "Runner, crossfiteur, nageur — vous cherchez un sport technique et cérébral pour compléter votre pratique. La boxe est le complément idéal.",
        image: cours2Landscape,
        alt: "Sportif en cours de boxe technique à Genève",
    },
    {
        title: "Le compétiteur amateur",
        description: "Vous voulez préparer un combat, obtenir votre licence SwissBoxing, progresser en sparring encadré. Nicolas connaît le chemin.",
        image: nicolasPortrait,
        alt: "Préparation combat amateur boxe Genève",
    },
];

const typesDePratique = [
    {
        title: "Boxe fitness & cardio",
        description: "Brûler des calories, se défouler, sculpter son corps. Le travail au sac et aux pattes d'ours offre un entraînement complet sans aucun contact. Le format idéal pour commencer.",
        icon: "lucide:heart-pulse",
    },
    {
        title: "Boxe technique & progression",
        description: "Apprendre les vrais fondamentaux : garde, déplacements, jab, direct, crochet, esquives. Progresser séance après séance avec un coach qui corrige chaque geste.",
        icon: "lucide:target",
    },
    {
        title: "Boxe compétition & sparring",
        description: "Pour ceux qui veulent aller sur le ring. Sparring encadré, préparation physique et mentale, suivi nutritionnel. Le chemin vers le combat amateur, avec un coach de coin expérimenté.",
        icon: "lucide:swords",
    },
];

const faqs = [
    {
        question: "Combien coûte un cours de boxe à Genève ?",
        answer: "Les tarifs varient selon le format. Chez Bis Repetita : CHF 40.- pour un cours collectif Round by Round (8 pers. max), CHF 120.- pour un coaching solo, CHF 140.- pour un duo. La première séance d'essai est gratuite. <a href='/tarifs' class='text-primary hover:underline'>Voir tous les tarifs</a>.",
    },
    {
        question: "À quel âge peut-on commencer la boxe ?",
        answer: "Il n'y a pas d'âge limite pour débuter. Nos élèves ont entre 25 et 65 ans. La boxe éducative s'adapte à chaque condition physique — l'important est d'être encadré par un professionnel qui ajuste l'intensité.",
    },
    {
        question: "Quel équipement faut-il pour débuter ?",
        answer: "Pour votre première séance : une tenue de sport confortable et des baskets propres suffisent. Gants, bandes et tout le matériel technique sont fournis par le studio. Si vous souhaitez acheter vos propres gants par la suite, comptez entre CHF 50 et 80.",
    },
    {
        question: "La boxe est-elle dangereuse pour un débutant ?",
        answer: "Non. La boxe éducative se pratique sans contact entre participants. Tout le travail se fait au sac et aux pattes d'ours tenues par le coach. Il n'y a aucun sparring tant que vous ne le demandez pas — et même là, c'est progressif et encadré. <a href='/services/corporate#faq' class='text-primary hover:underline'>En savoir plus sur la sécurité</a>.",
    },
    {
        question: "Combien de séances par semaine pour progresser ?",
        answer: "Deux séances par semaine est le rythme idéal pour un débutant : assez pour progresser, pas assez pour s'épuiser. Vous verrez des résultats techniques et physiques dès les 4 premières semaines.",
    },
    {
        question: "Comment se passe un premier cours de boxe ?",
        answer: "On commence par un échauffement doux (corde, mobilité), puis on passe aux fondamentaux : position de garde, déplacements, premiers coups sur les pattes d'ours. Le coach ajuste tout en temps réel à votre niveau. Vous repartez fatigué mais jamais blessé. <a href='/contact' class='text-primary hover:underline'>Réserver votre séance d'essai gratuite</a>.",
    },
    {
        question: "Y a-t-il du contact dès le premier cours ?",
        answer: "Non. Nos séances sont sans contact par défaut. Vous frappez le sac et les pattes d'ours, jamais une autre personne. Le sparring n'arrive que bien plus tard, sur demande, après une progression technique validée par le coach.",
    },
    {
        question: "La boxe fait-elle maigrir ?",
        answer: "Une séance de boxe de 60 minutes brûle entre 500 et 800 calories selon l'intensité — plus que la course à pied ou le vélo elliptique. Combinée à une alimentation équilibrée, la boxe est l'un des sports les plus efficaces pour la perte de poids et le raffermissement.",
    },
];
---

<BaseLayout {metadata}>
    <Fragment slot="head">
        <Schema
            type="FAQPage"
            data={{
                faqs: faqs.map((f) => ({
                    question: f.question,
                    answer: f.answer.replace(/<[^>]*>/g, ""),
                })),
            }}
        />
        <Schema
            type="BreadcrumbList"
            data={{
                breadcrumbs: [
                    { name: "Accueil", href: "/" },
                    { name: "Cours de Boxe à Genève", href: "/cours-de-boxe-geneve" },
                ],
            }}
        />
    </Fragment>

    <!-- 1. Hero (DARK, centered, informationnel) -->
    <Hero
        variant="centered"
        title={`Cours de Boxe à <span class="font-display text-primary">Genève</span>`}
        description="Le guide complet pour choisir votre cours de boxe à Genève : formats, profils, tarifs, premiers pas. Par les coachs de Bis Repetita."
        actions={[
            {
                text: "Découvrir nos formules",
                href: "/services",
                variant: "primary",
                icon: "lucide:arrow-right",
            },
            {
                text: "Lire le guide",
                href: "#profils",
                variant: "secondary",
            },
        ]}
        classes={{ container: "min-h-[60vh]" }}
    />

    <!-- 2. Stats (LIGHT) -->
    <Stats
        stats={stats}
        badge="Boxe à Genève"
        badgeHref="#profils"
        variant="wide"
        intro="Genève compte plus d'une quinzaine de clubs et studios de boxe — du club associatif historique au studio privé haut de gamme. Comment s'y retrouver ? Ce guide vous aide à choisir en fonction de votre profil, vos objectifs et votre budget."
    />

    <!-- 3. EquipmentPanels — Pour quel profil ? -->
    <GsapReveal animation="fadeUp">
        <EquipmentPanels
            id="profils"
            tagline="Pour quel profil ?"
            title="4 profils, 4 parcours de boxe à Genève"
            panels={profilPanels}
        />
    </GsapReveal>

    <!-- 4. Features — Types de pratique -->
    <GsapReveal animation="fadeUp">
        <Features
            tagline="Types de pratique"
            title="Trois manières de pratiquer la boxe à Genève"
            features={typesDePratique}
            columns={3}
        />
    </GsapReveal>

    <!-- 4a. Première séance — absorbe le longtail "première séance / débuter" -->
    <GsapReveal animation="fadeUp">
        <Container class="py-16 md:py-24" id="premiere-seance">
            <SectionTitle
                badge="Premiers pas"
                title={`Votre première séance de boxe, <span class='text-primary'>minute par minute</span>`}
                class="mb-12"
            />
            <p class="text-lg text-foreground/70 max-w-3xl mx-auto -mt-6 mb-12 text-center">
                Vous arrivez au studio, La Voie-Creuse 16. Vestiaire privé, douche et serviettes fournis — vous enfilez une tenue de sport, le reste est sur place. Voici comment se déroulent les 60 minutes, sans aucun sparring ni mise en situation de combat.
            </p>
            <div class="grid gap-8 md:grid-cols-2 max-w-4xl mx-auto">
                <article class="border border-border rounded-2xl p-6">
                    <h3 class="text-xl font-display font-medium mb-3">Échauffement <span class="text-primary text-base">· 10-15 min</span></h3>
                    <p class="text-foreground/70">
                        Corde à sauter, mobilité articulaire, shadow boxing léger. Le coach observe votre posture, votre coordination, votre souffle. C'est déjà du travail technique, même si ça n'en a pas l'air.
                    </p>
                </article>
                <article class="border border-border rounded-2xl p-6">
                    <h3 class="text-xl font-display font-medium mb-3">Technique de base <span class="text-primary text-base">· 20 min</span></h3>
                    <p class="text-foreground/70">
                        La garde, le jab, le direct arrière, le déplacement latéral. Le coach décompose chaque geste, vous le répétez, il corrige en temps réel : position des pieds, rotation du buste, retour de la main. C'est précis, pas brutal.
                    </p>
                </article>
                <article class="border border-border rounded-2xl p-6">
                    <h3 class="text-xl font-display font-medium mb-3">Travail aux pattes d'ours <span class="text-primary text-base">· 15 min</span></h3>
                    <p class="text-foreground/70">
                        Le coach enfile les pattes d'ours et vous enchaînez les combinaisons. Vous frappez une cible mouvante, vous dosez votre puissance, vous coordonnez bras et jambes. La partie que la plupart des débutants trouvent la plus addictive.
                    </p>
                </article>
                <article class="border border-border rounded-2xl p-6">
                    <h3 class="text-xl font-display font-medium mb-3">Retour au calme <span class="text-primary text-base">· 5-10 min</span></h3>
                    <p class="text-foreground/70">
                        Étirements, abdominaux légers, bilan de séance. Le coach vous donne un ou deux points à travailler pour la prochaine fois. Vous repartez fatigué mais jamais blessé, les bases posées et l'envie de revenir.
                    </p>
                </article>
            </div>
        </Container>
    </GsapReveal>

    <!-- 4a-bis. Les freins les plus courants — objection-handling débutant -->
    <GsapReveal animation="fadeUp">
        <Container class="py-16 md:py-24" id="freins">
            <SectionTitle
                badge="Lever les doutes"
                title={`Les freins les plus courants <span class='text-primary'>(et pourquoi ils ne tiennent pas)</span>`}
                class="mb-12"
            />
            <div class="grid gap-8 md:grid-cols-2 max-w-4xl mx-auto">
                <article class="border border-border rounded-2xl p-6">
                    <h3 class="text-xl font-display font-medium mb-3">« Je vais prendre des coups »</h3>
                    <p class="text-foreground/70">
                        Non. Pas au début, et jamais sans votre accord. Un cours débutant se concentre sur la technique : posture, garde, déplacements, frappes sur sac et pattes d'ours. Le sparring n'intervient qu'après plusieurs mois, uniquement si vous le souhaitez.
                    </p>
                </article>
                <article class="border border-border rounded-2xl p-6">
                    <h3 class="text-xl font-display font-medium mb-3">« J'ai 35 ans, c'est trop tard »</h3>
                    <p class="text-foreground/70">
                        C'est l'âge moyen de nos débutants. Commencer à 30, 35 ou 40 ans est tout à fait courant. Vous n'êtes pas là pour devenir champion du monde, mais pour vous sentir bien et progresser. Le corps s'adapte, le coach aussi.
                    </p>
                </article>
                <article class="border border-border rounded-2xl p-6">
                    <h3 class="text-xl font-display font-medium mb-3">« Je n'ai pas le physique »</h3>
                    <p class="text-foreground/70">
                        Personne ne l'a en arrivant. La condition physique se construit avec la pratique. Les premières séances sont calibrées pour votre niveau réel, pas pour celui que vous imaginez ne pas avoir. Au bout d'un mois, vous sentirez déjà la différence.
                    </p>
                </article>
                <article class="border border-border rounded-2xl p-6">
                    <h3 class="text-xl font-display font-medium mb-3">« L'ambiance des clubs me fait peur »</h3>
                    <p class="text-foreground/70">
                        Un frein réel. Les clubs d'association ont parfois une atmosphère compétitive qui ne convient pas à tout le monde. C'est une des raisons d'être du <a href="/blog/studio-boxe-prive-vs-salle-classique-geneve" class="text-primary hover:underline">studio privé</a> : un espace fermé, un coaching individualisé, aucun regard extérieur.
                    </p>
                </article>
            </div>
        </Container>
    </GsapReveal>

    <!-- 4b. Choisir votre format — maillage interne pillar → 7 services -->
    <GsapReveal animation="fadeUp">
        <Container class="py-16 md:py-24" id="formats">
            <SectionTitle
                badge="Choisir votre format"
                title={`7 formats pour pratiquer la boxe à <span class='text-primary'>Genève</span>`}
                class="mb-12"
            />
            <p class="text-lg text-foreground/70 max-w-3xl mx-auto -mt-6 mb-12 text-center">
                Solo, duo, petit groupe, collectif, à domicile, en entreprise ou cadre 100 % féminin — chaque format répond à un besoin précis. Voici comment choisir.
            </p>
            <div class="grid gap-8 md:grid-cols-2">
                <article class="border border-border rounded-2xl p-6 hover:border-primary transition-colors">
                    <h3 class="text-2xl font-display font-medium mb-3">Coaching Privé</h3>
                    <p class="text-foreground/70 mb-4">
                        Le format historique de Bis Repetita : un coach, votre rythme, votre programme. Hub qui regroupe les déclinaisons solo, duo, trio et petit groupe. Idéal si vous cherchez une progression rapide et mesurable.
                    </p>
                    <a href="/services/coaching-prive" class="text-primary hover:underline font-medium">
                        Découvrir le coaching privé →
                    </a>
                </article>
                <article class="border border-border rounded-2xl p-6 hover:border-primary transition-colors">
                    <h3 class="text-2xl font-display font-medium mb-3">Coaching Solo</h3>
                    <p class="text-foreground/70 mb-4">
                        Séance 1-on-1 avec Nicolas de Boccard. Le format le plus exigeant et le plus rapide pour transformer votre technique de boxe à Genève. 60 minutes 100 % pour vous.
                    </p>
                    <a href="/services/coaching-solo" class="text-primary hover:underline font-medium">
                        Découvrir le coaching solo →
                    </a>
                </article>
                <article class="border border-border rounded-2xl p-6 hover:border-primary transition-colors">
                    <h3 class="text-2xl font-display font-medium mb-3">Coaching Duo & Trio</h3>
                    <p class="text-foreground/70 mb-4">
                        Le coaching privé à deux ou trois — même qualité d'encadrement, coût partagé. Format apprécié des couples, amis ou collègues qui veulent progresser ensemble.
                    </p>
                    <a href="/services/coaching-duo-trio" class="text-primary hover:underline font-medium">
                        Découvrir le coaching duo / trio →
                    </a>
                </article>
                <article class="border border-border rounded-2xl p-6 hover:border-primary transition-colors">
                    <h3 class="text-2xl font-display font-medium mb-3">Small Group Training</h3>
                    <p class="text-foreground/70 mb-4">
                        6 personnes maximum, ratio coach/élèves favorable. Le format intermédiaire entre coaching privé et cours collectif, pour ceux qui veulent l'énergie du groupe sans diluer le suivi technique.
                    </p>
                    <a href="/services/small-group-training" class="text-primary hover:underline font-medium">
                        Découvrir le small group training →
                    </a>
                </article>
                <article class="border border-border rounded-2xl p-6 hover:border-primary transition-colors">
                    <h3 class="text-2xl font-display font-medium mb-3">Coaching à Domicile</h3>
                    <p class="text-foreground/70 mb-4">
                        Le studio se déplace chez vous, partout dans le canton de Genève. Matériel professionnel inclus (gants, pattes d'ours, tapis, corde). Pour les agendas saturés ou les expats à Cologny, Versoix, Champel ou Carouge.
                    </p>
                    <a href="/services/coaching-boxe-domicile" class="text-primary hover:underline font-medium">
                        Découvrir le coaching à domicile →
                    </a>
                </article>
                <article class="border border-border rounded-2xl p-6 hover:border-primary transition-colors">
                    <h3 class="text-2xl font-display font-medium mb-3">Round by Round</h3>
                    <p class="text-foreground/70 mb-4">
                        Cours collectif structuré en rounds chronométrés, 8 participants maximum, 2 coachs sur le ring. Le format le plus accessible (40 CHF la séance) pour découvrir la boxe anglaise dans un cadre exigeant.
                    </p>
                    <a href="/services/round-by-round" class="text-primary hover:underline font-medium">
                        Découvrir Round by Round →
                    </a>
                </article>
                <article class="border border-border rounded-2xl p-6 hover:border-primary transition-colors">
                    <h3 class="text-2xl font-display font-medium mb-3">Corporate & Team Building</h3>
                    <p class="text-foreground/70 mb-4">
                        Programmes pour entreprises genevoises : team building, séances bien-être au travail, masterclass technique. Intervention au studio La Voie-Creuse 16 ou dans vos locaux. Devis sous 48 h.
                    </p>
                    <a href="/services/corporate" class="text-primary hover:underline font-medium">
                        Découvrir les programmes corporate →
                    </a>
                </article>
                <article class="border border-border rounded-2xl p-6 hover:border-primary transition-colors">
                    <h3 class="text-2xl font-display font-medium mb-3">Boxe Femme</h3>
                    <p class="text-foreground/70 mb-4">
                        Cadre privé, sans contact, sans regard masculin. Format dédié aux femmes qui veulent débuter la boxe à Genève sereinement, en solo, en duo ou en petit groupe 100 % féminin.
                    </p>
                    <a href="/services/boxe-femme" class="text-primary hover:underline font-medium">
                        Découvrir la boxe femme →
                    </a>
                </article>
            </div>
        </Container>
    </GsapReveal>

    <!-- 5. RelatedArticles — Articles du blog -->
    <GsapReveal animation="fadeUp">
        <RelatedArticles
            title="Nos articles sur la boxe à Genève"
            badge="Ressources"
            maxItems={6}
            excludePostIds={["boxe-femme-geneve-guide-complet"]}
        />
    </GsapReveal>

    <!-- 6. FAQ -->
    <GsapReveal animation="fadeUp">
        <FAQ
            title="Questions fréquentes sur les cours de boxe à Genève"
            subtitle="Les réponses aux questions les plus posées par les débutants."
            items={faqs}
        />
    </GsapReveal>

    <!-- 7. CTABanner (informationnel → vers /services) -->
    <GsapReveal animation="fadeUp">
        <CTABanner
            variant="brushed-full"
            title="Prêt à commencer ?"
            subtitle="Découvrez nos programmes"
            cta={{ text: "Voir les formules", href: "/services" }}
        />
    </GsapReveal>
</BaseLayout>
