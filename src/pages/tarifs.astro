---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/widgets/Hero.astro";
import CTABanner from "../components/widgets/CTABanner.astro";
import GsapReveal from "../components/widgets/GsapReveal.astro";

const metadata = {
    title: "Tarifs — Coaching privé et cours de boxe à Genève",
    description:
        "Découvrez les tarifs du studio Bis Repetita à Genève. Coaching privé dès 150 CHF, cours collectifs Round by Round et programmes corporate sur mesure.",
};
---

<BaseLayout {metadata}>
    <Hero
        title={`Nos <span class="font-display text-primary">Tarifs</span>`}
        description="Des formules adaptées à chaque objectif. Coaching privé, cours collectifs ou programmes corporate."
        actions={[
            {
                text: "Nous contacter",
                href: "/contact",
                variant: "primary",
                icon: "lucide:arrow-right",
            },
        ]}
        classes={{ container: "min-h-[50vh]" }}
    />

    <!-- TODO: Grille claire par service, packs, politique d'essai -->

    <GsapReveal animation="fadeUp">
        <CTABanner
            variant="brushed-full"
            title="Une question sur nos tarifs ?"
            subtitle="Tarifs & formules"
            cta={{ text: "Nous contacter", href: "/contact" }}
        />
    </GsapReveal>
</BaseLayout>
