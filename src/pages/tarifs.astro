---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/widgets/Hero.astro";
import PricingNav from "../components/widgets/PricingNav.astro";
import QuizFormule from "../components/widgets/QuizFormule.astro";
import PricingTable from "../components/widgets/PricingTable.astro";
import Features from "../components/widgets/Features.astro";
import FAQ from "../components/widgets/FAQ.astro";
import CTABanner from "../components/widgets/CTABanner.astro";
import GsapReveal from "../components/widgets/GsapReveal.astro";
import WidgetWrapper from "../components/widgets/WidgetWrapper.astro";
import Headline from "../components/ui/Headline.astro";
import Button from "../components/ui/Button.astro";
import Schema from "../components/seo/Schema.astro";
import { Icon } from "astro-icon/components";
import heroImage from "../assets/studio-interior.webp";

const metadata = {
    title: "Tarifs & Abonnements Coaching Sportif Genève",
    description:
        "Transparence et flexibilité. Découvrez les tarifs des coachings solo, duo et cours collectifs à Genève. Séance d'essai offerte. Studio premium aux Pâquis.",
};

// --- Nav items ---
const navItems = [
    { label: "Solo", anchorId: "solo" },
    { label: "Duo & Trio", anchorId: "duo-trio" },
    { label: "Small Group", anchorId: "small-group" },
    { label: "Round by Round", anchorId: "boxe-groupe" },
    { label: "Corporate", anchorId: "corporate" },
];

// --- Coaching Privé 1:1 ---
const soloTiers = [
    {
        name: "Séance unité",
        description: "Premier contact avec le coaching individuel.",
        price: "CHF 120.-",
        priceNote: "/ séance",
        features: [
            "60 minutes de coaching",
            "1 participant",
            "Bilan personnalisé",
            "Matériel fourni",
            "Sans engagement",
        ],
        cta: { text: "Réserver", href: "/contact" },
    },
    {
        name: "Pack 10 séances",
        description: "La formule pour progresser durablement.",
        price: "CHF 1'100.-",
        priceNote: "/ 10 séances",
        highlighted: true,
        popularLabel: "Recommandé",
        features: [
            "10 × 60 minutes",
            "Programme personnalisé",
            "Suivi de progression",
            "Matériel fourni",
            "Tarif préférentiel",
        ],
        cta: { text: "Réserver", href: "/contact" },
    },
];

// --- Duo & Trio ---
const duoTiers = [
    {
        name: "Séance duo",
        description: "Un coaching privé à deux.",
        price: "CHF 140.-",
        priceNote: "/ séance (prix total)",
        features: [
            "60 minutes de coaching",
            "2 participants",
            "Programme adapté au duo",
            "Matériel fourni",
            "Sans engagement",
        ],
        cta: { text: "Réserver", href: "/contact" },
    },
    {
        name: "Pack 10 duo",
        description: "L'engagement partagé pour progresser ensemble.",
        price: "CHF 1'300.-",
        priceNote: "/ 10 séances",
        highlighted: true,
        popularLabel: "Recommandé",
        features: [
            "10 × 60 minutes",
            "Programme personnalisé duo",
            "Suivi de progression",
            "Matériel fourni",
            "Tarif préférentiel",
        ],
        cta: { text: "Réserver", href: "/contact" },
    },
    {
        name: "Séance trio",
        description: "Trois complices, un coach dédié.",
        price: "CHF 160.-",
        priceNote: "/ séance (prix total)",
        features: [
            "60 minutes de coaching",
            "3 participants",
            "Programme adapté au groupe",
            "Matériel fourni",
            "Sans engagement",
        ],
        cta: { text: "Réserver", href: "/contact" },
    },
    {
        name: "Pack 10 trio",
        description: "L'engagement partagé pour progresser à trois.",
        price: "CHF 1'500.-",
        priceNote: "/ 10 séances",
        highlighted: true,
        popularLabel: "Recommandé",
        features: [
            "10 × 60 minutes",
            "Programme personnalisé trio",
            "Suivi de progression",
            "Matériel fourni",
            "Tarif préférentiel",
        ],
        cta: { text: "Réserver", href: "/contact" },
    },
];

// --- Small Group ---
const smallGroupTiers = [
    {
        name: "Séance unité",
        description: "Un cours small group à la carte.",
        price: "CHF 200.-",
        priceNote: "/ séance",
        features: [
            "60 minutes de coaching",
            "4 participants",
            "Programme structuré",
            "Matériel fourni",
        ],
        cta: { text: "Réserver", href: "/contact" },
    },
    {
        name: "Pack 10 séances",
        description: "L'engagement qui fait la différence.",
        price: "CHF 1'800.-",
        priceNote: "/ 10 séances",
        highlighted: true,
        popularLabel: "Recommandé",
        features: [
            "10 × 60 minutes",
            "4 participants",
            "Suivi de progression",
            "Matériel fourni",
            "Tarif préférentiel",
        ],
        cta: { text: "Réserver", href: "/contact" },
    },
];

// --- Round by Round ---
const rbrTiers = [
    {
        name: "Séance unité",
        description: "Un cours collectif Round by Round à la carte.",
        price: "CHF 40.-",
        priceNote: "/ séance",
        features: [
            "60 minutes de coaching",
            "8 participants max",
            "2 coachs",
            "Matériel fourni",
            "Sans engagement",
        ],
        cta: { text: "Réserver", href: "/contact" },
    },
];

// --- Features "Inclus" ---
const features = [
    {
        title: "Matériel fourni",
        description:
            "Gants, bandes, protections — tout est inclus dans chaque séance. Venez simplement en tenue de sport.",
        icon: "lucide:shield-check",
    },
    {
        title: "Vestiaires & douches",
        description:
            "Le studio dispose de vestiaires et douches pour que vous puissiez vous entraîner avant ou après le travail.",
        icon: "lucide:droplets",
    },
    {
        title: "Séance d'essai offerte",
        description:
            "Testez gratuitement les cours Round by Round ou demandez un bilan initial pour le coaching privé.",
        icon: "lucide:gift",
    },
    {
        title: "Suivi personnalisé",
        description:
            "Chaque client bénéficie d'un programme adapté à ses objectifs, son niveau et ses contraintes.",
        icon: "lucide:chart-line",
    },
    {
        title: "Studio premium aux Pâquis",
        description:
            "Un espace exclusif au cœur de Genève, équipé de matériel professionnel haut de gamme.",
        icon: "lucide:map-pin",
    },
    {
        title: "Flexibilité totale",
        description:
            "Packs sans abonnement obligatoire, valables 6 mois. Annulation gratuite 24h à l'avance.",
        icon: "lucide:calendar-check",
    },
];

// --- FAQ enrichie ---
const faqs = [
    {
        question: "Proposez-vous une séance d'essai ?",
        answer: "Oui ! Les cours collectifs Round by Round incluent une première séance d'essai gratuite. Pour le coaching privé, nous proposons un bilan initial pour définir vos objectifs. <a href='/contact' class='text-primary hover:underline'>Réservez votre séance d'essai</a>.",
    },
    {
        question: "Les packs ont-ils une date d'expiration ?",
        answer: "Les packs de séances sont valables 6 mois à compter de la date d'achat. Ce délai permet de maintenir une régularité d'entraînement tout en restant flexible.",
    },
    {
        question: "Peut-on partager un pack avec son conjoint ou un ami ?",
        answer: "Les packs de coaching privé sont nominatifs. Pour vous entraîner ensemble, optez pour les séances Duo ou Trio qui offrent un tarif groupé avantageux.",
    },
    {
        question: "Quels modes de paiement acceptez-vous ?",
        answer: "Nous acceptons les paiements par virement bancaire, Twint et espèces. Pour les entreprises, nous émettons des factures avec un délai de 30 jours.",
    },
    {
        question: "Comment fonctionne la facturation corporate ?",
        answer: "Les <a href='/services/corporate' class='text-primary hover:underline'>programmes corporate</a> font l'objet d'un devis personnalisé. La facturation se fait par virement avec un délai de 30 jours. <a href='/contact' class='text-primary hover:underline'>Contactez-nous</a> pour en discuter.",
    },
    {
        question: "Les séances de coaching sont-elles déductibles des impôts ou prises en charge par l'assurance à Genève ?",
        answer: "À Genève, les frais de coaching sportif ne sont généralement pas déductibles des impôts pour les particuliers. Certaines assurances complémentaires (Helsana, Swica, CSS) proposent des contributions santé qui peuvent couvrir une partie des cours. Nous vous conseillons de vérifier auprès de votre assureur.",
    },
    {
        question: "Quelle est votre politique d'annulation ?",
        answer: "Toute annulation effectuée au moins 24 heures à l'avance est gratuite. En cas d'annulation tardive (moins de 24h) ou de no-show, la séance est décomptée du pack. Nous comprenons les imprévus — contactez-nous en cas de circonstances exceptionnelles.",
    },
    {
        question: "Où se situe le studio ? Est-il facile d'accès depuis les Eaux-Vives, Plainpalais ou Cologny ?",
        answer: "Le studio Bis Repetita est situé à La Voie-Creuse 16, 1202 Genève, dans le quartier des Pâquis. Facilement accessible en transports publics depuis les Eaux-Vives, Plainpalais, Cologny et Carouge (arrêt à proximité). Parking disponible à quelques minutes à pied. <a href='/contact#map' class='text-primary hover:underline'>Voir le plan d'accès</a>.",
    },
];

// --- OfferCatalog data ---
const offers = [
    { name: "Coaching Privé 1:1", description: "Séances individuelles de boxe avec programme personnalisé à Genève.", url: "/services/coaching-solo" },
    { name: "Coaching Duo & Trio", description: "Coaching privé partagé à 2 ou 3 personnes.", url: "/services/coaching-duo-trio" },
    { name: "Small Group Training", description: "Coaching en petit groupe de 6 personnes maximum.", url: "/services/small-group-training" },
    { name: "Round by Round", description: "Cours collectifs de boxe accessibles à tous, sans combat.", url: "/services/round-by-round" },
    { name: "Programme Corporate", description: "Boxe en entreprise à Genève — team building et bien-être au travail.", url: "/services/corporate" },
];
---

<BaseLayout {metadata}>
    <Fragment slot="head">
        <Schema type="FAQPage" data={{ faqs: faqs.map(f => ({ question: f.question, answer: f.answer.replace(/<[^>]*>/g, '') })) }} />
        <Schema type="OfferCatalog" data={{ offers }} />
        <Schema type="BreadcrumbList" data={{ breadcrumbs: [{ name: "Accueil", href: "/" }, { name: "Tarifs", href: "/tarifs" }] }} />
    </Fragment>

    <div class="theme-light">

    {/* 1. Hero */}
    <Hero
        title={`Tarifs et <span class="font-display text-primary">Formules</span>`}
        description="Des formules transparentes et flexibles pour chaque objectif. Coaching privé, duo, petit groupe, cours collectifs ou programme corporate."
        actions={[
            {
                text: "Réserver mon bilan initial",
                href: "/contact",
                variant: "primary",
                icon: "lucide:arrow-right",
            },
        ]}
        image={heroImage}
        imageAlt="Studio de boxe Bis Repetita à Genève"
        lightOverlay={true}
        ctaStyle="dark"
        classes={{ container: "min-h-[70vh]" }}
    />

    {/* 2. PricingNav (sticky) */}
    <PricingNav items={navItems} />

    {/* 3. Quiz */}
    <GsapReveal animation="fadeUp">
        <QuizFormule />
    </GsapReveal>

    {/* 4. Coaching Privé 1:1 — #solo */}
    <GsapReveal animation="fadeUp">
        <PricingTable
            id="solo"
            tagline="Coaching Privé"
            title="Coaching Privé — Tarifs Séances Individuelles à Genève"
            subtitle="Chaque séance inclut un suivi personnalisé et une adaptation constante."
            tiers={soloTiers}
        />
        <div class="text-center -mt-8 mb-16">
            <p class="text-primary font-medium mb-1">🎁 Votre première séance est offerte</p>
            <p class="text-muted-foreground text-sm mb-3">Découvrez notre approche sans engagement. Si l'expérience vous plaît, un partage de votre ressenti sur Google aide d'autres sportifs à nous trouver.</p>
            <a href="/contact" class="text-primary hover:underline text-sm font-medium mb-4 inline-block">
                Réserver mon essai &rarr;
            </a>
            <p class="text-muted-foreground italic mb-4">L'investissement ultime pour des résultats sans compromis.</p>
            <a href="/services/coaching-solo" class="text-primary hover:underline text-sm font-medium">
                En savoir plus sur le coaching solo &rarr;
            </a>
        </div>
    </GsapReveal>

    {/* 5. Duo & Trio — #duo-trio */}
    <GsapReveal animation="fadeUp">
        <PricingTable
            id="duo-trio"
            tagline="Duo & Trio"
            title="Duo & Trio — Tarifs Coaching Partagé"
            subtitle="La qualité du privé avec le plaisir du partage."
            tiers={duoTiers}
            columns={2}
        />
        <div class="text-center -mt-8 mb-16">
            <p class="text-primary font-medium mb-1">🎁 Votre première séance est offerte</p>
            <p class="text-muted-foreground text-sm mb-3">Découvrez notre approche sans engagement. Si l'expérience vous plaît, un partage de votre ressenti sur Google aide d'autres sportifs à nous trouver.</p>
            <a href="/contact" class="text-primary hover:underline text-sm font-medium mb-4 inline-block">
                Réserver mon essai &rarr;
            </a>
            <p class="text-muted-foreground italic mb-4">Divisez les coûts, multipliez la motivation.</p>
            <a href="/services/coaching-duo-trio" class="text-primary hover:underline text-sm font-medium">
                En savoir plus sur le coaching duo & trio &rarr;
            </a>
        </div>
    </GsapReveal>

    {/* 6. Small Group — #small-group */}
    <GsapReveal animation="fadeUp">
        <PricingTable
            id="small-group"
            tagline="Small Group Training"
            title="Small Group Training — Abonnements Petit Groupe"
            subtitle="6 personnes max pour que Nicolas corrige chaque mouvement."
            tiers={smallGroupTiers}
            columns={2}
        />
        <div class="text-center -mt-8 mb-16">
            <p class="text-primary font-medium mb-1">🎁 Votre première séance est offerte</p>
            <p class="text-muted-foreground text-sm mb-3">Découvrez notre approche sans engagement. Si l'expérience vous plaît, un partage de votre ressenti sur Google aide d'autres sportifs à nous trouver.</p>
            <a href="/contact" class="text-primary hover:underline text-sm font-medium mb-4 inline-block">
                Réserver mon essai &rarr;
            </a>
            <p class="text-muted-foreground italic mb-4">Le compromis parfait entre prix et attention personnalisée.</p>
            <a href="/services/small-group-training" class="text-primary hover:underline text-sm font-medium">
                En savoir plus sur le small group training &rarr;
            </a>
        </div>
    </GsapReveal>

    {/* 7. Round by Round — #boxe-groupe */}
    <GsapReveal animation="fadeUp">
        <WidgetWrapper id="boxe-groupe">
            <Headline
                title="Cours Collectifs Round by Round — Tarifs Boxe Genève"
                subtitle="Accessible à tous, sans combat. 2 coachs par session."
                tagline="Round by Round"
                titleAs="h2"
                align="center"
                classes={{
                    container: "max-w-3xl mx-auto mb-12 text-center",
                    title: "text-4xl md:text-5xl font-medium tracking-tight font-display",
                }}
            />
            <div class="bg-card/60 backdrop-blur-sm rounded-3xl border border-border/50 p-8 md:p-12 max-w-4xl mx-auto">
                <div class="grid md:grid-cols-2 gap-10 items-center">
                    <div class="text-center md:text-left">
                        <span class="text-6xl md:text-7xl font-extrabold text-gradient-gold">CHF 40.-</span>
                        <p class="text-muted-foreground mt-2">/ séance</p>
                        <p class="text-foreground font-medium mt-4 text-lg">Un cours collectif Round by Round à la carte.</p>
                        <div class="mt-6">
                            <Button href="/contact" variant="primary" class="w-full md:w-auto">
                                Réserver une séance
                            </Button>
                        </div>
                    </div>
                    <div>
                        <ul class="space-y-4">
                            {rbrTiers[0].features.map((feature) => (
                                <li class="flex items-start gap-3 text-foreground/80">
                                    <Icon name="lucide:check" class="w-5 h-5 text-primary mt-0.5 shrink-0" />
                                    <span>{feature}</span>
                                </li>
                            ))}
                        </ul>
                    </div>
                </div>
                <div class="mt-10 pt-8 border-t border-border/50 text-center">
                    <p class="text-primary font-medium mb-1">Votre première séance est offerte</p>
                    <p class="text-muted-foreground text-sm">Découvrez notre approche sans engagement. Si l'expérience vous plaît, un partage de votre ressenti sur Google aide d'autres sportifs à nous trouver.</p>
                </div>
            </div>
            <div class="text-center mt-6">
                <p class="text-muted-foreground italic mb-4">Rejoignez le mouvement. 12 rounds pour se dépasser.</p>
                <a href="/services/round-by-round" class="text-primary hover:underline text-sm font-medium">
                    En savoir plus sur Round by Round &rarr;
                </a>
            </div>
        </WidgetWrapper>
    </GsapReveal>

    {/* 8. Corporate — #corporate */}
    <GsapReveal animation="fadeUp">
        <WidgetWrapper id="corporate">
            <Headline
                title="Programme Corporate — Boxe en Entreprise à Genève"
                subtitle="Plus qu'un cours, un levier de performance pour vos équipes."
                tagline="Corporate"
                titleAs="h2"
                align="center"
                classes={{
                    container: "max-w-3xl mx-auto mb-12 text-center",
                    title: "text-4xl md:text-5xl font-medium tracking-tight font-display",
                }}
            />
            <div class="max-w-3xl mx-auto">
                <div class="relative bg-card/60 backdrop-blur-sm rounded-3xl p-8 md:p-12 border border-border/50 overflow-hidden">
                    <div class="absolute top-0 inset-x-0 h-24 bg-gradient-to-b from-primary/5 to-transparent pointer-events-none" aria-hidden="true"></div>
                    <div class="relative z-10">
                        <ul class="space-y-4 mb-10">
                            <li class="flex items-start gap-3 text-foreground/80">
                                <span class="w-1.5 h-1.5 rounded-full bg-primary mt-2 shrink-0" aria-hidden="true"></span>
                                <span>Cours de boxe sur mesure pour vos collaborateurs — team building, bien-être, cohésion d'équipe</span>
                            </li>
                            <li class="flex items-start gap-3 text-foreground/80">
                                <span class="w-1.5 h-1.5 rounded-full bg-primary mt-2 shrink-0" aria-hidden="true"></span>
                                <span>Sessions au studio ou dans vos locaux à Genève et environs</span>
                            </li>
                            <li class="flex items-start gap-3 text-foreground/80">
                                <span class="w-1.5 h-1.5 rounded-full bg-primary mt-2 shrink-0" aria-hidden="true"></span>
                                <span>Formats flexibles : séance unique, programme récurrent, événement ponctuel</span>
                            </li>
                            <li class="flex items-start gap-3 text-foreground/80">
                                <span class="w-1.5 h-1.5 rounded-full bg-primary mt-2 shrink-0" aria-hidden="true"></span>
                                <span>Matériel professionnel fourni pour tous les participants</span>
                            </li>
                            <li class="flex items-start gap-3 text-foreground/80">
                                <span class="w-1.5 h-1.5 rounded-full bg-primary mt-2 shrink-0" aria-hidden="true"></span>
                                <span>Facturation entreprise avec délai de 30 jours</span>
                            </li>
                        </ul>
                        <div class="flex flex-col sm:flex-row gap-4 justify-center">
                            <Button href="/contact" variant="primary" size="lg">
                                Obtenir un devis sur-mesure
                            </Button>
                            <Button href="/plaquette-corporate.pdf" variant="secondary" size="lg">
                                Télécharger la plaquette
                            </Button>
                        </div>
                    </div>
                </div>
                <div class="text-center mt-6">
                    <a href="/services/corporate" class="text-primary hover:underline text-sm font-medium">
                        En savoir plus sur nos programmes corporate &rarr;
                    </a>
                </div>
            </div>
        </WidgetWrapper>
    </GsapReveal>

    {/* 9. Inclus dans chaque formule */}
    <GsapReveal animation="fadeUp">
        <Features
            tagline="Inclus"
            title="Inclus dans chaque formule"
            features={features}
            columns={3}
            isDark={true}
        />
    </GsapReveal>

    {/* 10. FAQ enrichie */}
    <GsapReveal animation="fadeUp">
        <FAQ
            title="Questions fréquentes — Tarifs"
            subtitle="Tout ce que vous devez savoir sur nos tarifs, formules et conditions."
            items={faqs}
        />
    </GsapReveal>

    {/* 11. CTABanner final */}
    <GsapReveal animation="fadeUp">
        <CTABanner
            variant="brushed-full"
            title="Prêt à commencer ?"
            subtitle="Tarifs & formules"
            description="Réservez votre séance d'essai gratuite ou demandez un bilan initial personnalisé."
            cta={{ text: "Réserver mon bilan initial", href: "/contact" }}
        />
    </GsapReveal>

    </div>{/* .theme-light */}
</BaseLayout>
