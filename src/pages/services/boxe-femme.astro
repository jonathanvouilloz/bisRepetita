---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/widgets/Hero.astro";
import Stats from "../../components/widgets/Stats.astro";
import Features from "../../components/widgets/Features.astro";
import SplitShowcase from "../../components/widgets/SplitShowcase.astro";
import ContentShowcase from "../../components/widgets/ContentShowcase.astro";
import PricingTable from "../../components/widgets/PricingTable.astro";
import FAQ from "../../components/widgets/FAQ.astro";
import CTABanner from "../../components/widgets/CTABanner.astro";
import RelatedServices from "../../components/widgets/RelatedServices.astro";
import GsapReveal from "../../components/widgets/GsapReveal.astro";
import Schema from "../../components/seo/Schema.astro";
import studioAtmosphere from "../../assets/studio-atmosphere.webp";
import coursPortrait from "../../assets/cours-portrait.webp";
import nicolasPortrait from "../../assets/nicolas-de-boccard.webp";

const metadata = {
    title: "Boxe pour Femmes à Genève",
    description:
        "Cours de boxe pour femmes à Genève. Coaching personnalisé, cadre bienveillant, sans contact. Studio privé, toutes formules. Séance d'essai gratuite.",
};

const stats = [
    { value: "40%", label: "De femmes", description: "Près de la moitié de nos élèves sont des femmes — débutantes ou confirmées." },
    { value: "1-3", label: "Participantes max", description: "En coaching privé, l'attention est totale. Pas de regard, pas de jugement." },
    { value: "0", label: "Contact obligatoire", description: "La boxe sans contact est notre format par défaut. Vous choisissez votre intensité." },
];

const features = [
    {
        title: "Confiance en soi",
        description:
            "Apprendre à se positionner, à frapper avec intention, à occuper l'espace. La boxe reconstruit la confiance depuis l'intérieur.",
        icon: "lucide:flame",
    },
    {
        title: "Forme physique complète",
        description:
            "Cardio, renforcement, souplesse, coordination. 60 minutes de boxe brûlent plus de calories qu'une heure de running — sans l'ennui.",
        icon: "lucide:heart-pulse",
    },
    {
        title: "Cadre respectueux & safe",
        description:
            "Un studio privé, un coach professionnel, zéro ambiance de vestiaire. Vous venez pour vous, dans un environnement pensé pour votre confort.",
        icon: "lucide:shield-check",
    },
    {
        title: "Sans contact par défaut",
        description:
            "Tout le travail se fait au sac et aux pattes d'ours. Aucun contact entre participantes, sauf demande explicite et progression validée.",
        icon: "lucide:hand",
    },
    {
        title: "Progression mesurable",
        description:
            "Technique, endurance, puissance : Nicolas mesure vos progrès et ajuste le programme. Vous voyez la différence en quelques semaines.",
        icon: "lucide:trending-up",
    },
];

const tiers = [
    {
        name: "Coaching Solo",
        description: "Le format idéal pour débuter : 100% d'attention, 0% de regard.",
        price: "CHF 120.-",
        priceNote: "/ séance",
        features: [
            "60 min de coaching individuel",
            "Programme 100% personnalisé",
            "Sans contact",
            "Matériel fourni",
            "Séance d'essai gratuite",
        ],
        cta: { text: "Réserver", href: "/contact" },
    },
    {
        name: "Coaching Duo",
        description: "Venez avec une amie. Même qualité, plus de fun.",
        price: "CHF 140.-",
        priceNote: "/ séance (pour 2)",
        features: [
            "60 min de coaching partagé",
            "Programme adapté aux deux",
            "Sans contact",
            "Matériel fourni",
            "Séance d'essai gratuite",
        ],
        cta: { text: "Réserver", href: "/contact" },
        highlighted: true,
        popularLabel: "Le plus choisi",
    },
    {
        name: "Round by Round",
        description: "L'énergie du groupe, 8 personnes maximum.",
        price: "CHF 40.-",
        priceNote: "/ séance",
        features: [
            "60 min — technique + cardio",
            "8 participantes maximum",
            "2 coachs encadrants",
            "Sans contact",
            "Matériel fourni",
        ],
        cta: { text: "Réserver", href: "/contact" },
    },
];

const faqs = [
    {
        question: "Comment se passe la première séance pour une femme débutante ?",
        answer: "On commence par un échauffement en douceur (corde, shadow boxing, mobilité), puis on passe aux fondamentaux : position de garde, déplacements, premiers coups sur les pattes d'ours tenues par Nicolas. Tout est adapté à votre rythme. Vous repartez fatiguée mais jamais blessée — et souvent surprise d'avoir autant aimé.",
    },
    {
        question: "Quel équipement apporter ?",
        answer: "Une tenue de sport confortable et des baskets propres suffisent. Gants, bandes et tout le matériel technique sont fournis par le studio. Si vous souhaitez acheter vos propres gants par la suite, on vous conseille sur la taille et la marque adaptées à vos mains.",
    },
    {
        question: "Y a-t-il du contact physique ?",
        answer: "Non. Nos séances sont sans contact par défaut. Vous frappez le sac et les pattes d'ours, jamais une autre personne. Le sparring n'est introduit que bien plus tard, sur demande explicite, après une progression technique validée par le coach.",
    },
    {
        question: "Faut-il être en bonne condition physique pour commencer ?",
        answer: "Non. La boxe s'adapte à votre condition actuelle. Nicolas ajuste l'intensité en temps réel — chaque exercice a une version accessible et une version avancée. Nos élèves vont du profil sédentaire complet à la sportive confirmée.",
    },
    {
        question: "À quelle fréquence s'entraîner pour voir des résultats ?",
        answer: "Deux séances par semaine est le rythme idéal pour débuter. Vous verrez les premiers résultats (énergie, tonus, confiance) dès les 3-4 premières semaines. En 3 mois, la transformation physique et mentale est significative.",
    },
    {
        question: "Comment s'habiller pour un cours de boxe ?",
        answer: "Un legging ou short confortable, un t-shirt ou brassière de sport, des baskets propres à semelle plate de préférence. Nous fournissons serviettes et vestiaires avec douches. Venez comme vous êtes — la seule tenue interdite, c'est les talons.",
    },
];
---

<BaseLayout {metadata}>
    <Fragment slot="head">
        <Schema
            type="Service"
            data={{
                title: "Cours de Boxe pour Femmes à Genève",
                description: metadata.description,
                url: "https://bisrepetita.ch/services/boxe-femme",
                serviceType: "Cours de boxe pour femmes",
            }}
        />
        <Schema
            type="Person"
            data={{
                title: "Nicolas de Boccard",
                description: "Head Coach & Fondateur de Bis Repetita. Dans la boxe depuis 2002, entraineur agréé Swiss Boxing. Licencié SwissBoxing #102860.",
            }}
        />
        <Schema
            type="FAQPage"
            data={{
                faqs: faqs.map((f) => ({
                    question: f.question,
                    answer: f.answer.replace(/<[^>]*>/g, ""),
                })),
            }}
        />
        <Schema
            type="BreadcrumbList"
            data={{
                breadcrumbs: [
                    { name: "Accueil", href: "/" },
                    { name: "Programmes", href: "/services" },
                    { name: "Boxe Femme", href: "/services/boxe-femme" },
                ],
            }}
        />
    </Fragment>

    <!-- 1. Hero (DARK) -->
    <Hero
        title={`Boxe <span class="font-display text-primary">Femme</span> à Genève`}
        description="Un coaching de boxe pensé pour les femmes. Cadre privé, sans contact, progression à votre rythme. Que vous n'ayez jamais mis de gants ou que vous cherchiez à franchir un palier."
        image={studioAtmosphere}
        imageAlt="Cours de boxe pour femmes à Genève — studio Bis Repetita"
        locationBadge={{ text: "La Voie-Creuse 16, 1202 Genève" }}
        actions={[
            {
                text: "Réserver votre séance d'essai",
                href: "/contact",
                variant: "primary",
                icon: "lucide:arrow-right",
            },
            {
                text: "Voir les tarifs",
                href: "#tarifs",
                variant: "secondary",
            },
        ]}
        ctaStyle="outline-gold"
    />

    <!-- 2. Stats (LIGHT — rupture visuelle) -->
    <Stats
        stats={stats}
        badge="Boxe Femme"
        badgeHref="#pourquoi"
        variant="wide"
        intro="Un cadre pensé pour les femmes qui veulent découvrir la boxe ou franchir un palier — sans les freins habituels des clubs traditionnels. Studio privé, coaching personnalisé, sans contact par défaut."
    />

    <!-- 3. Features bento (DARK) — Pourquoi la boxe -->
    <GsapReveal animation="fadeUp">
        <Features
            id="pourquoi"
            tagline="Pourquoi la boxe"
            title="Ce que la boxe apporte aux femmes"
            features={features}
            columns={3}
            headlineAlign="left"
            bento="2-3"
        />
    </GsapReveal>

    <!-- 4. SplitShowcase — Une séance type -->
    <GsapReveal animation="fadeUp">
        <SplitShowcase
            tagline="Une séance type"
            title="60 minutes pensées pour vous"
            image={coursPortrait}
            imageAlt="Séance de boxe pour femmes au studio Bis Repetita Genève"
            items={[
                {
                    title: "Échauffement & mobilité",
                    description:
                        "On commence en douceur : corde, shadow boxing, mobilité articulaire. Le corps se prépare sans stress, le mental se connecte.",
                },
                {
                    title: "Technique sur pattes d'ours",
                    description:
                        "Le cœur de la séance. Nicolas tient les pattes, corrige chaque geste. Jab, direct, crochet — vous apprenez les vrais fondamentaux de la boxe anglaise.",
                },
                {
                    title: "Circuit & retour au calme",
                    description:
                        "Renforcement ciblé (abdos, bras, cardio), puis étirements et débrief. Vous repartez vidée mais jamais cassée.",
                },
            ]}
        />
    </GsapReveal>

    <!-- 5. ContentShowcase — Craintes levées -->
    <GsapReveal animation="fadeUp">
        <ContentShowcase
            tagline="Vos questions, nos réponses"
            title="Les craintes les plus courantes — et pourquoi elles ne tiennent pas"
            items={[
                {
                    title: "Peur du contact",
                    description:
                        "Nos séances sont sans contact par défaut. Vous frappez le sac et les pattes d'ours, jamais une autre personne. Le contact n'arrive que si vous le demandez, après des mois de pratique.",
                },
                {
                    title: "Peur du jugement",
                    description:
                        "Studio privé, groupes de 1 à 3 personnes maximum. Pas de miroirs géants, pas de regard. Un environnement pensé pour vous concentrer sur vous-même.",
                },
                {
                    title: 'Peur de devenir "trop musclée"',
                    description:
                        "La boxe affine et tonifie. Le volume musculaire ne vient qu'avec un régime et un entraînement de force spécifique. La boxe fait le contraire : elle sèche, elle sculpte, elle allonge.",
                },
                {
                    title: "Peur de la douleur",
                    description:
                        "Les courbatures des premiers jours passent vite. Les gants protègent vos mains. Les bandes protègent vos poignets. Nicolas calibre l'intensité à votre condition — toujours progressive, jamais brutale.",
                },
            ]}
        />
    </GsapReveal>

    <!-- 6. PricingTable -->
    <GsapReveal animation="fadeUp">
        <PricingTable
            id="tarifs"
            tagline="Nos formules"
            title="Quelle formule choisir ?"
            tiers={tiers}
        />
    </GsapReveal>

    <!-- 7. Testimonials — TODO -->
    {/* <GsapReveal animation="fadeUp">
        <Testimonials
            tagline="Elles témoignent"
            title="Ce qu'elles disent de leur expérience"
            testimonials={[
                { quote: "TODO — Témoignage femme débutante", name: "À confirmer", role: "Débutante" },
                { quote: "TODO — Témoignage femme confirmée", name: "À confirmer", role: "Pratiquante régulière" },
                { quote: "TODO — Témoignage transformation", name: "À confirmer", role: "Objectif forme" },
            ]}
        />
    </GsapReveal> */}

    <!-- 8. RelatedServices -->
    <RelatedServices currentSlug="boxe-femme" />

    <!-- 9. FAQ -->
    <GsapReveal animation="fadeUp">
        <FAQ
            title="Questions fréquentes"
            subtitle="Tout ce que vous devez savoir sur la boxe pour femmes à Genève."
            items={faqs}
        />
    </GsapReveal>

    <!-- 10. CTABanner -->
    <GsapReveal animation="fadeUp">
        <CTABanner
            variant="brushed-full"
            title="Prête à essayer ?"
            subtitle="Première séance offerte"
            cta={{ text: "Réserver ma séance d'essai", href: "/contact" }}
        />
    </GsapReveal>
</BaseLayout>
