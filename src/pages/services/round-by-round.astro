---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/widgets/Hero.astro";
import CTABanner from "../../components/widgets/CTABanner.astro";
import GsapReveal from "../../components/widgets/GsapReveal.astro";
import Schema from "../../components/seo/Schema.astro";

const metadata = {
    title: "Round by Round — Cours collectifs de boxe à Genève",
    description:
        "Cours collectifs de boxe Round by Round à Genève. Une méthode unique en rounds de 3 minutes qui allie technique, cardio et renforcement musculaire.",
};
---

<BaseLayout {metadata}>
    <Fragment slot="head">
        <Schema
            type="Service"
            data={{
                title: "Round by Round — Cours collectifs de boxe",
                description: metadata.description,
            }}
        />
    </Fragment>

    <Hero
        title={`Round by <span class="font-display text-primary">Round</span>`}
        description="Cours collectifs structurés en rounds. Technique de boxe, cardio et renforcement dans une ambiance électrique. 8 participants maximum."
        actions={[
            {
                text: "Voir le planning",
                href: "/contact",
                variant: "primary",
                icon: "lucide:arrow-right",
            },
            {
                text: "Voir les tarifs",
                href: "/tarifs",
                variant: "secondary",
            },
        ]}
        classes={{ container: "min-h-[60vh]" }}
    />

    <!-- TODO: Planning intégré, format, esprit du cours, progression -->

    <GsapReveal animation="fadeUp">
        <CTABanner
            variant="brushed-full"
            title="Prêt à rejoindre le ring ?"
            subtitle="Votre premier round"
            cta={{ text: "S'inscrire", href: "/contact" }}
        />
    </GsapReveal>
</BaseLayout>
