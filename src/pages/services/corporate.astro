---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/widgets/Hero.astro";
import CTABanner from "../../components/widgets/CTABanner.astro";
import GsapReveal from "../../components/widgets/GsapReveal.astro";
import Schema from "../../components/seo/Schema.astro";

const metadata = {
    title: "Programme Corporate — Boxe en entreprise à Genève",
    description:
        "Programmes de boxe corporate à Genève. Team building, bien-être en entreprise et événements sur mesure avec Bis Repetita. Renforcez la cohésion de vos équipes.",
};
---

<BaseLayout {metadata}>
    <Fragment slot="head">
        <Schema
            type="Service"
            data={{
                title: "Programme Corporate de Boxe",
                description: metadata.description,
            }}
        />
    </Fragment>

    <Hero
        title={`Programme <span class="font-display text-primary">Corporate</span>`}
        description="Renforcez la cohésion de vos équipes avec la boxe. Team building, séances bien-être et programmes sur mesure pour les entreprises."
        actions={[
            {
                text: "Demander un devis",
                href: "/contact",
                variant: "primary",
                icon: "lucide:arrow-right",
            },
        ]}
        classes={{ container: "min-h-[60vh]" }}
    />

    <!-- TODO: Pitch entreprise, deux formats (déplacement/studio), bénéfices, processus devis -->

    <GsapReveal animation="fadeUp">
        <CTABanner
            variant="brushed-full"
            title="Un projet corporate en tête ?"
            subtitle="Programmes entreprise"
            cta={{ text: "Demander un devis", href: "/contact" }}
        />
    </GsapReveal>
</BaseLayout>
