---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/widgets/Hero.astro";
import CTABanner from "../../components/widgets/CTABanner.astro";
import GsapReveal from "../../components/widgets/GsapReveal.astro";
import Schema from "../../components/seo/Schema.astro";

const metadata = {
    title: "Coaching Privé de Boxe à Genève",
    description:
        "Séances de coaching privé de boxe à Genève avec Nicolas de Boccard. Entraînement individuel ou en petit groupe (1 à 6 personnes). Programme sur mesure adapté à vos objectifs.",
};
---

<BaseLayout {metadata}>
    <Fragment slot="head">
        <Schema
            type="Service"
            data={{
                title: "Coaching Privé de Boxe",
                description: metadata.description,
            }}
        />
    </Fragment>

    <Hero
        title={`Coaching <span class="font-display text-primary">Privé</span>`}
        description="Séances individuelles ou en petit groupe (jusqu'à 6 personnes). Un accompagnement sur mesure adapté à vos objectifs."
        actions={[
            {
                text: "Réserver une séance",
                href: "/contact",
                variant: "primary",
                icon: "lucide:arrow-right",
            },
            {
                text: "Voir les tarifs",
                href: "/tarifs",
                variant: "secondary",
            },
        ]}
        classes={{ container: "min-h-[60vh]" }}
    />

    <!-- TODO: Déroulé d'une séance, profils adaptés, tarifs. CTA: séance d'essai -->

    <GsapReveal animation="fadeUp">
        <CTABanner
            variant="brushed-full"
            title="Prêt à commencer votre transformation ?"
            subtitle="Première séance"
            cta={{ text: "Réserver", href: "/contact" }}
        />
    </GsapReveal>
</BaseLayout>
