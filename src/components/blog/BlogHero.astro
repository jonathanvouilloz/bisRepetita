---
export interface Props {
  title?: string;
  subtitle?: string;
  categories?: string[];
  activeCategory?: string;
}

const {
  title = "Nos Publications",
  subtitle = "Actualites, conseils et articles sur la boxe, le bien-etre et la performance.",
  categories = [],
  activeCategory,
} = Astro.props;

const uniqueCategories = [...new Set(categories)].sort();
---

<section class="pt-32 pb-12 md:pt-40 md:pb-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <span
        class="section-label inline-block mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-primary"
      >
        Blog
      </span>
      <h1
        class="font-heading text-4xl font-medium tracking-tight text-foreground md:text-6xl"
      >
        {title}
      </h1>
      <p class="mt-4 text-lg text-muted-foreground">
        {subtitle}
      </p>
    </div>

    <div class="mx-auto mt-8 max-w-3xl">
      <div class="h-px w-full bg-border"></div>
    </div>

    {
      uniqueCategories.length > 0 && (
        <nav
          class="mx-auto mt-6 flex max-w-3xl flex-wrap items-center justify-center gap-2"
          aria-label="Filtrer par categorie"
        >
          <a
            href="/blog"
            class:list={[
              "rounded-full px-4 py-1.5 text-sm font-medium transition-colors duration-200",
              !activeCategory
                ? "bg-foreground text-background"
                : "bg-muted text-muted-foreground hover:bg-border hover:text-foreground",
            ]}
          >
            Tous
          </a>
          {uniqueCategories.map((cat) => (
            <a
              href={`/blog/category/${cat}`}
              class:list={[
                "rounded-full px-4 py-1.5 text-sm font-medium transition-colors duration-200",
                activeCategory === cat
                  ? "bg-foreground text-background"
                  : "bg-muted text-muted-foreground hover:bg-border hover:text-foreground",
              ]}
            >
              {cat}
            </a>
          ))}
        </nav>
      )
    }
  </div>
</section>
