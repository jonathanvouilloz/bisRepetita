---
import { type CollectionEntry, render } from "astro:content";
import { slugify } from "../../utils/slugify";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { remarkPluginFrontmatter } = await render(post);

const readingTime = remarkPluginFrontmatter?.minutesRead
  ? `${Math.ceil(remarkPluginFrontmatter.minutesRead)} min de lecture`
  : "";

const formattedDate = post.data.pubDate.toLocaleDateString("fr-CH", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});

const categoryLabel = post.data.category
  ? post.data.category.charAt(0).toUpperCase() + post.data.category.slice(1)
  : "";
---

<article
  class="group flex flex-col rounded-2xl border border-border bg-card p-3 transition-all duration-300 hover:shadow-lg hover:shadow-black/5"
>
  <a href={`/blog/${post.id}`} class="block">
    <div class="relative overflow-hidden rounded-xl">
      {
        post.data.image ? (
          <img
            src={post.data.image}
            alt={post.data.title}
            class="aspect-video w-full object-cover transition-transform duration-500 group-hover:scale-105"
          />
        ) : (
          <div class="flex aspect-video w-full items-center justify-center bg-muted">
            <span class="text-2xl text-muted-foreground/30">BIS</span>
          </div>
        )
      }
    </div>
  </a>

  <div class="flex flex-1 flex-col pt-4 px-1">
    {
      categoryLabel && (
        <a
          href={`/blog/category/${slugify(post.data.category)}`}
          class="mb-2 inline-block w-fit rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary transition-colors hover:bg-primary/20"
        >
          {categoryLabel}
        </a>
      )
    }

    <a href={`/blog/${post.id}`} class="block flex-1">
      <h3
        class="font-heading text-xl sm:text-2xl font-medium tracking-tight text-foreground group-hover:text-primary transition-colors duration-200"
      >
        {post.data.title}
      </h3>
      <p class="mt-2 text-sm text-muted-foreground line-clamp-2">
        {post.data.description}
      </p>
    </a>

    <div class="mt-4 flex items-center gap-2 text-xs text-muted-foreground">
      <time datetime={post.data.pubDate.toISOString()}>
        {formattedDate}
      </time>
      <span aria-hidden="true">&middot;</span>
      <span>{post.data.author}</span>
      {readingTime && <span aria-hidden="true">&middot;</span>}
      {readingTime && <span>{readingTime}</span>}
    </div>
  </div>
</article>
