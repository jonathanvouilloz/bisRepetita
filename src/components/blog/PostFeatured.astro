---
import { type CollectionEntry, render } from "astro:content";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { remarkPluginFrontmatter } = await render(post);

const readingTime = remarkPluginFrontmatter?.minutesRead
  ? `${Math.ceil(remarkPluginFrontmatter.minutesRead)} min de lecture`
  : "";

const formattedDate = post.data.pubDate.toLocaleDateString("fr-CH", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});

const categoryLabel = post.data.category
  ? post.data.category.charAt(0).toUpperCase() + post.data.category.slice(1)
  : "";
---

<article class="group">
  <a href={`/blog/${post.id}`} class="block">
    <div class="rounded-2xl border border-border bg-card p-5">
      <!-- Image -->
      <div class="relative overflow-hidden rounded-xl">
        {
          post.data.image ? (
            <img
              src={post.data.image}
              alt={post.data.title}
              class="aspect-video w-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
          ) : (
            <div class="flex aspect-video w-full items-center justify-center rounded-xl bg-muted">
              <span class="text-4xl text-muted-foreground/30">BIS</span>
            </div>
          )
        }
      </div>

      <!-- Contenu -->
      <div class="pt-5">
        <div class="flex items-center gap-2 text-sm uppercase tracking-wide text-muted-foreground">
          <time datetime={post.data.pubDate.toISOString()}>
            {formattedDate}
          </time>
          <span aria-hidden="true">&mdash;</span>
          <span>{post.data.author}</span>
        </div>

        <h2
          class="mt-3 font-heading text-4xl font-medium tracking-tight text-foreground md:text-5xl leading-[1.1]"
        >
          {post.data.title}
        </h2>

        <p class="mt-3 text-base text-muted-foreground line-clamp-3 max-w-lg">
          {post.data.description}
        </p>

        <div class="mt-6">
          <span
            class="inline-flex items-center rounded-full bg-primary/10 px-5 py-2 text-base font-medium text-primary transition-colors group-hover:bg-primary/20"
          >
            Lire l'article
            <svg
              class="ml-2 h-5 w-5 transition-transform group-hover:translate-x-1"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </span>
        </div>
      </div>
    </div>
  </a>
</article>
