---
import { Image } from "astro:assets";
import SectionTitle from "../ui/SectionTitle.astro";
import type { ImageMetadata } from "astro";

interface Props {
    tagline?: string;
    title?: string;
    image: ImageMetadata;
    imageAlt?: string;
    items?: Array<{ title: string; description: string }>;
    isReversed?: boolean;
    id?: string;
}

const {
    tagline,
    title,
    image,
    imageAlt = "",
    items = [],
    isReversed = false,
    id,
} = Astro.props;
---

<section id={id} class="relative w-full">
    <div class:list={["grid md:grid-cols-[1fr_auto_1fr]", isReversed && "direction-reverse"]}>
        {/* Text column */}
        <div class:list={[
            "px-4 md:px-6 lg:px-8 py-16 md:py-24 flex flex-col justify-center",
            isReversed ? "md:order-3" : "md:order-1",
        ]}>
            <div class:list={[
                "max-w-3xl",
                isReversed ? "mr-auto" : "ml-auto",
            ]}>
                {(tagline || title) && (
                    <SectionTitle
                        badge={tagline}
                        title={title}
                        align="left"
                        class="mb-8"
                    />
                )}

                {items.length > 0 && (
                    <div class="space-y-6 my-8">
                        {items.map(({ title: titleItem, description: descriptionItem }, idx) => (
                            <div class="flex items-start gap-4">
                                <span class="text-2xl font-extrabold text-primary/40 font-mono leading-none mt-1 shrink-0">
                                    {String(idx + 1).padStart(2, "0")}
                                </span>
                                <div class="flex-1">
                                    <div class="w-8 h-px bg-primary/30 mb-3"></div>
                                    {titleItem && (
                                        <h3 class="text-lg font-medium leading-6">
                                            {titleItem}
                                        </h3>
                                    )}
                                    {descriptionItem && (
                                        <p class="mt-2 text-muted-foreground">
                                            {descriptionItem}
                                        </p>
                                    )}
                                </div>
                            </div>
                        ))}
                    </div>
                )}
            </div>
        </div>

        {/* Spacer column */}
        <div class:list={[
            "hidden md:block w-12 lg:w-16",
            isReversed ? "md:order-2" : "md:order-2",
        ]} />

        {/* Image column */}
        <div class:list={[
            "relative min-h-[300px] md:max-h-[600px]",
            isReversed ? "md:order-1" : "md:order-3",
        ]}>
            <Image
                src={image}
                alt={imageAlt}
                class="w-full h-full object-cover absolute inset-0"
                widths={[400, 800, 1200]}
                sizes="(max-width: 768px) 100vw, 50vw"
            />
        </div>
    </div>
</section>
