---
import type { StatsProps } from "../../types/types";
import { Icon } from "astro-icon/components";
import Button from "../ui/Button.astro";

interface Props extends StatsProps {
    variant?: "default" | "wide";
    cta?: { text: string; href: string };
}

const { stats, id, badge, badgeHref, intro, variant = "default", cta } = Astro.props as Props;
---

<section id={id} class="bg-white text-neutral-900">
    <div class="mx-auto max-w-7xl px-6 md:px-12 lg:px-20 py-20 md:py-32">

        {variant === "wide" ? (
            <!-- Wide variant: full-width intro, stats + badge bottom-right -->
            <div>
                {intro && (
                    <p class="text-xl md:text-2xl lg:text-3xl text-neutral-700 leading-relaxed max-w-5xl mb-20 md:mb-24">
                        {intro}
                    </p>
                )}

                <div class="grid grid-cols-1 sm:grid-cols-3 gap-10 md:gap-16">
                    {stats.map((stat) => (
                        <div class="group">
                            <div
                                class="gsap-count-up text-5xl md:text-6xl lg:text-7xl text-neutral-900 mb-3 leading-none whitespace-nowrap"
                                data-value={stat.value}
                            >
                                {stat.value}
                            </div>
                            <div class="text-sm font-semibold text-neutral-900 uppercase tracking-wider mb-2">
                                {stat.label}
                            </div>
                            {stat.description && (
                                <p class="text-sm text-neutral-500 leading-relaxed">
                                    {stat.description}
                                </p>
                            )}
                        </div>
                    ))}
                </div>

                {badge && (
                    <div class="flex justify-end mt-16">
                        {badgeHref ? (
                            <a href={badgeHref} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-neutral-900 text-white text-sm font-medium hover:bg-neutral-800 transition-colors">
                                {badge}
                                <Icon name="lucide:arrow-right" class="w-4 h-4" />
                            </a>
                        ) : (
                            <span class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-neutral-900 text-white text-sm font-medium">
                                {badge}
                                <Icon name="lucide:arrow-right" class="w-4 h-4" />
                            </span>
                        )}
                    </div>
                )}
            </div>
        ) : (
            <!-- Default variant: badge left, intro+stats right -->
            <div class="grid grid-cols-1 md:grid-cols-[2fr_3fr] gap-10 md:gap-20">

                {badge && (
                    <div class="md:pt-1">
                        {badgeHref ? (
                            <a href={badgeHref} class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-neutral-900 text-white text-sm font-medium hover:bg-neutral-800 transition-colors">
                                {badge}
                                <Icon name="lucide:arrow-right" class="w-4 h-4" />
                            </a>
                        ) : (
                            <span class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-neutral-900 text-white text-sm font-medium">
                                {badge}
                                <Icon name="lucide:arrow-right" class="w-4 h-4" />
                            </span>
                        )}
                    </div>
                )}

                <div>
                    {intro && (
                        <p class="text-lg md:text-xl lg:text-2xl text-neutral-700 leading-relaxed max-w-3xl mb-14">
                            {intro}
                        </p>
                    )}

                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-10 md:gap-16">
                        {stats.map((stat) => (
                            <div class="group">
                                <div
                                    class="gsap-count-up text-5xl md:text-6xl lg:text-7xl text-neutral-900 mb-3 leading-none"
                                    data-value={stat.value}
                                >
                                    {stat.value}
                                </div>
                                <div class="text-sm font-semibold text-neutral-900 uppercase tracking-wider mb-2">
                                    {stat.label}
                                </div>
                                {stat.description && (
                                    <p class="text-sm text-neutral-500 leading-relaxed">
                                        {stat.description}
                                    </p>
                                )}
                            </div>
                        ))}
                    </div>
                </div>

            </div>
        )}

    </div>
</section>
