---
import Container from "../ui/Container.astro";
import { Image } from "astro:assets";
import { siteConfig } from "../../config/site";
import nicolasPortrait from "../../assets/nicolas-de-boccard.webp";

const inputClasses =
    "block w-full rounded-xl border border-border bg-muted px-4 py-3 text-foreground placeholder:text-muted-foreground focus:border-primary focus:ring-primary/20 transition-all outline-none focus:ring-4";
---

<section class="pt-40 pb-16 md:pt-48 md:pb-24">
    <Container>
        <div class="grid gap-12 md:grid-cols-[1fr_1px_1fr] md:gap-10 lg:gap-14 items-start max-w-7xl mx-auto">
            <!-- Colonne gauche — titre + infos -->
            <div class="md:sticky md:top-32 space-y-8">
                <div class="gsap-reveal" data-animation="fadeUp">
                    <p class="section-label text-muted-foreground mb-4">CONTACT & DEVIS</p>
                    <h1 class="text-4xl md:text-5xl font-bold font-display tracking-tight mb-6">
                        Passez à <span class="text-primary">l'action</span>
                    </h1>
                    <p class="text-lg text-muted-foreground leading-relaxed">
                        Réservation, question ou demande de devis — nous vous répondons personnellement sous 24h.
                    </p>
                </div>

                <div class="space-y-5 gsap-reveal" data-animation="fadeUp" data-delay="0.1">
                    <a
                        href={`tel:${siteConfig.contact.phone.replace(/\s/g, "")}`}
                        class="flex items-center gap-3 group"
                    >
                        <svg class="w-5 h-5 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                        </svg>
                        <span class="text-foreground group-hover:text-primary transition-colors">
                            {siteConfig.contact.phone}
                        </span>
                    </a>

                    <a
                        href={`mailto:${siteConfig.contact.email}`}
                        class="flex items-center gap-3 group"
                    >
                        <svg class="w-5 h-5 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                        <span class="text-foreground group-hover:text-primary transition-colors">
                            {siteConfig.contact.email}
                        </span>
                    </a>

                    <div class="flex items-center gap-3">
                        <svg class="w-5 h-5 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        <span class="text-foreground">
                            {siteConfig.contact.address}
                        </span>
                    </div>
                </div>

                <!-- Touch perso -->
                <div class="border-t border-border pt-6 gsap-reveal" data-animation="fadeUp" data-delay="0.2">
                    <div class="flex items-center gap-4">
                        <Image
                            src={nicolasPortrait}
                            alt="Nicolas de Boccard"
                            class="w-14 h-14 rounded-full object-cover"
                            widths={[56, 112]}
                            sizes="56px"
                        />
                        <div>
                            <p class="font-medium text-foreground">Nicolas de Boccard</p>
                            <p class="text-sm text-muted-foreground">Fondateur & Coach</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Divider vertical -->
            <div class="hidden md:block bg-border self-stretch"></div>

            <!-- Colonne droite — formulaire -->
            <div class="gsap-reveal" data-animation="fadeUp" data-delay="0.15">
                <div class="bg-card rounded-3xl border border-border p-8 md:p-10 shadow-[var(--shadow-gold-card)]">
                    <form
                        name="contact"
                        method="POST"
                        data-netlify="true"
                        netlify-honeypot="bot-field"
                        class="space-y-5"
                    >
                        <input type="hidden" name="form-name" value="contact" />
                        <p class="hidden">
                            <label>
                                Ne remplissez pas ce champ si vous êtes humain :
                                <input name="bot-field" />
                            </label>
                        </p>

                        <!-- Prénom + Nom -->
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label for="firstname" class="block text-sm font-medium text-foreground/80 mb-2">
                                    Prénom
                                </label>
                                <input
                                    type="text"
                                    name="firstname"
                                    id="firstname"
                                    required
                                    autocomplete="given-name"
                                    placeholder="Votre prénom"
                                    class={inputClasses}
                                />
                            </div>
                            <div>
                                <label for="lastname" class="block text-sm font-medium text-foreground/80 mb-2">
                                    Nom
                                </label>
                                <input
                                    type="text"
                                    name="lastname"
                                    id="lastname"
                                    required
                                    autocomplete="family-name"
                                    placeholder="Votre nom"
                                    class={inputClasses}
                                />
                            </div>
                        </div>

                        <!-- Email + Téléphone -->
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label for="email" class="block text-sm font-medium text-foreground/80 mb-2">
                                    Email
                                </label>
                                <input
                                    type="email"
                                    name="email"
                                    id="email"
                                    required
                                    autocomplete="email"
                                    placeholder="votre@email.com"
                                    class={inputClasses}
                                />
                            </div>
                            <div>
                                <label for="phone" class="block text-sm font-medium text-foreground/80 mb-2">
                                    Téléphone <span class="text-muted-foreground">(opt.)</span>
                                </label>
                                <input
                                    type="tel"
                                    name="phone"
                                    id="phone"
                                    autocomplete="tel"
                                    placeholder="+41 79 000 00 00"
                                    class={inputClasses}
                                />
                            </div>
                        </div>

                        <!-- Objet -->
                        <div>
                            <label for="subject" class="block text-sm font-medium text-foreground/80 mb-2">
                                Objet
                            </label>
                            <select
                                name="subject"
                                id="subject"
                                class={inputClasses}
                            >
                                <option value="">Sélectionnez l'objet de votre message</option>
                                <option value="seance-essai">Réserver une séance d'essai</option>
                                <option value="devis-prive">Demande de devis — Coaching privé</option>
                                <option value="devis-duo-trio">Demande de devis — Duo ou Trio</option>
                                <option value="devis-corporate">Demande de devis — Programme corporate</option>
                                <option value="renseignement">Renseignement général</option>
                                <option value="autre">Autre</option>
                            </select>
                        </div>

                        <!-- Message -->
                        <div>
                            <label for="message" class="block text-sm font-medium text-foreground/80 mb-2">
                                Message
                            </label>
                            <textarea
                                name="message"
                                id="message"
                                rows="5"
                                required
                                placeholder="Votre message..."
                                class:list={[inputClasses, "resize-none"]}
                            ></textarea>
                        </div>

                        <!-- Bouton -->
                        <button
                            type="submit"
                            class="shimmer-btn w-full rounded-xl px-8 py-3.5 text-sm font-bold tracking-wide transition-all relative overflow-hidden"
                        >
                            Envoyer
                            <svg class="inline-block w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                            </svg>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </Container>
</section>
